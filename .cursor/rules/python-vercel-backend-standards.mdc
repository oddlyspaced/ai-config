### Route Patterns
```python
# app/api/v1/users.py
from flask import jsonify, request
from pydantic import ValidationError

from app.api.v1 import api_v1_bp
from app.auth.decorators import require_auth
from app.schemas.user import UserCreate, UserResponse, UserUpdate
from app.services.user_service import UserService

@api_v1_bp.route("/users", methods=["GET"])
@require_auth
def list_users():
    """List users with pagination."""
    page = request.args.get("page", 1, type=int)
    per_page = request.args.get("per_page", 20, type=int)
    result = UserService.list_paginated(page=page, per_page=per_page)
    return jsonify(result)

@api_v1_bp.route("/users", methods=["POST"])
def create_user():
    """Create a new user."""
    try:
        data = UserCreate.model_validate(request.get_json())
    except ValidationError as e:
        return jsonify({"error": "Validation failed", "details": e.errors()}), 422
    user = UserService.create(data)
    return jsonify(UserResponse.model_validate(user).model_dump()), 201

@api_v1_bp.route("/users/<int:user_id>", methods=["GET"])
@require_auth
def get_user(user_id: int):
    """Get a single user by ID."""
    user = UserService.get_by_id(user_id)
    if not user:
        return jsonify({"error": "User not found"}), 404
    return jsonify(UserResponse.model_validate(user).model_dump())

@api_v1_bp.route("/users/<int:user_id>", methods=["PATCH"])
@require_auth
def update_user(user_id: int):
    """Partially update a user."""
    try:
        data = UserUpdate.model_validate(request.get_json())
    except ValidationError as e:
        return jsonify({"error": "Validation failed", "details": e.errors()}), 422
    user = UserService.update(user_id, data)
    if not user:
        return jsonify({"error": "User not found"}), 404
    return jsonify(UserResponse.model_validate(user).model_dump())

@api_v1_bp.route("/users/<int:user_id>", methods=["DELETE"])
@require_auth
def delete_user(user_id: int):
    """Delete a user."""
    success = UserService.delete(user_id)
    if not success:
        return jsonify({"error": "User not found"}), 404
    return "", 204
```

### Health Check
```python
# app/api/health.py
from flask import Blueprint, jsonify

health_bp = Blueprint("health", __name__)

@health_bp.route("/health")
def health_check():
    """Health check endpoint for monitoring."""
    return jsonify({"status": "healthy"})

@health_bp.route("/health/ready")
def readiness_check():
    """Readiness check - verifies database connectivity."""
    try:
        from app.extensions import db
        db.session.execute(db.text("SELECT 1"))
        return jsonify({"status": "ready", "database": "connected"})
    except Exception as e:
        return jsonify({"status": "not ready", "database": str(e)}), 503
