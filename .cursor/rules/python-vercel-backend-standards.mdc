### Test Pattern
```python
# tests/test_users.py
def test_create_user(client, db):
    response = client.post("/api/v1/users", json={
        "email": "new@example.com",
        "name": "New User",
        "password": "securepassword123",
    })
    assert response.status_code == 201
    data = response.get_json()
    assert data["email"] == "new@example.com"
    assert data["name"] == "New User"
    assert "id" in data

def test_create_user_invalid_email(client, db):
    response = client.post("/api/v1/users", json={
        "email": "not-an-email",
        "name": "Test",
        "password": "securepassword123",
    })
    assert response.status_code == 422

def test_get_user_unauthorized(client, db):
    response = client.get("/api/v1/users/1")
    assert response.status_code == 401

def test_get_user(client, db, auth_headers):
    # Create user first
    create_resp = client.post("/api/v1/users", json={
        "email": "user@example.com",
        "name": "Test User",
        "password": "securepassword123",
    })
    user_id = create_resp.get_json()["id"]

    response = client.get(f"/api/v1/users/{user_id}", headers=auth_headers)
    assert response.status_code == 200
    assert response.get_json()["email"] == "user@example.com"
