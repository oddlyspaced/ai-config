## Don't Do This

### ❌ Using Pages Router
```typescript
// pages/index.tsx - OLD PATTERN
export default function Home() {
  return <div>Home</div>;
}
```

### ❌ Forgetting 'use client' for Hooks
```typescript
// Will error: useState used in Server Component
import { useState } from 'react';

export default function Counter() {
  const [count, setCount] = useState(0); // ❌ Error!
  return <div>{count}</div>;
}
```

### ❌ Not Awaiting Async Params
```typescript
// Next.js 15 will error
export default function Page({ params }) {
  return <div>{params.id}</div>; // ❌ Error!
}
```

### ❌ Using `any` Type
```typescript
// Bad type safety
function processData(data: any) { // ❌ Never use 'any'
  return data.value;
}
```

### ❌ Inline Functions in Props
```typescript
// Causes unnecessary re-renders
export default function Parent() {
  return (
    <Child onClick={() => console.log('clicked')} /> // ❌ New function every render
  );
}
```

### ❌ Missing Alt Text on Images
```typescript
<Image src="/image.jpg" alt="" /> // ❌ Empty alt is bad for a11y
```

### ❌ Using SSR When SSG Works
```typescript
// Wastes Vercel function executions
export default async function Page() {
  const data = await fetch('url', { cache: 'no-store' }); // ❌ Expensive!
  return <div>{data}</div>;
}
```

